# ─────────────────────────────────────────────────────────────────────────────
# Audiris — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# Resend API — contact form email delivery
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email address that receives contact form submissions
CONTACT_EMAIL=hello@audiris.com

# Plausible analytics domain (optional — omit to disable analytics)
# Get from: https://plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=audiris.com

# Calendly booking URL (optional — shows fallback email if not set)
# Example: https://calendly.com/audiris/discovery
NEXT_PUBLIC_CALENDLY_URL=
